local T = script:FindFirstAncestorOfClass("Tool")
local Act, Deb, Eq, TaskA, TaskB, PARAM = false, false, false, nil, nil, RaycastParams.new()
PARAM.IgnoreWater = true PARAM.FilterType = Enum.RaycastFilterType.Exclude
local baseAccel = 80
local maxSpeed = 600
local steerRate =  1
local DEBUG_LIFE = .1
local PCOL = (function() return Color3.fromRGB(math.abs(math.sin(tick())) * 255, math.abs(math.cos(tick())) * 125, 0) end)() 
local BCOL = (function() return Color3.fromRGB(math.abs(math.sin(tick())) * 125, math.abs(math.cos(tick())) * 255, 0) end)() 
local DCOL = (function() return Color3.fromRGB(math.abs(math.sin(tick())) * 255, math.abs(math.cos(tick())) * 255, 0) end)() 
function FindFirstChildOfNameAndClass(Where: Instance, Name: string, Class: string)
	local found = Where:FindFirstChild(Name)
	if found and found:IsA(Class) then return found end
	for i,v in Where:GetChildren() do
		if v:IsA(Class) and v.Name == Name then return v end
	end
	return nil
end
local _DBG = FindFirstChildOfNameAndClass(workspace, '_DBG_PATH', 'Folder') or Instance.new("Folder")
_DBG.Name = "_DBG_PATH"
_DBG.Parent = workspace
local EffectInstance= {}
local Debris = game:GetService('Debris')
local ts = game:GetService('TweenService')

function FadePart(p, t)
	Debris:AddItem(p, t + 1)
	task.delay(t, function()
		ts:Create(p, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 1, Size = p.Size * .1} ):Play()
	end)
end
function ClampVector3(vector: Vector3)
	local max_value = 600
	local Veccal = vector
	if vector.X ~= vector.X then Veccal = Vector3.new(Random.new():NextInteger(-max_value, max_value), vector.Y, vector.Z) end
	if Veccal.Y ~= Veccal.Y then Veccal = Vector3.new(Veccal.X, Random.new():NextInteger(-max_value, max_value), Veccal.Z) end
	if Veccal.Z ~= Veccal.Z then Veccal = Vector3.new(Veccal.X, Veccal.Y, Random.new():NextInteger(-max_value, max_value)) end
	local clampedX = math.clamp(vector.X, -max_value, max_value)
	local clampedY = math.clamp(vector.Y, -max_value, max_value)
	local clampedZ = math.clamp(vector.Z, -max_value, max_value)
	Veccal = Vector3.new(clampedX, clampedY, clampedZ)
	return Veccal
end
function HandleRaycastHit(velocity: Vector3, raycastResult: RaycastResult)
	local normal = raycastResult.Normal
	local threshold = 45 / (1 + velocity.Magnitude * .1)
	local angle = math.deg(math.acos(normal:Dot(velocity.Unit)))
	if angle < threshold then
		local projectedVelocity = velocity - normal * velocity:Dot(normal)
		return ClampVector3(projectedVelocity), false
	else
		local reflectedVelocity = velocity - 2 * velocity:Dot(normal) * normal
		return ClampVector3(reflectedVelocity), true
	end
end
local function calculateBounceAngle(rayDirection: Vector3, raycastResult: RaycastResult) : Vector3
	local normal = raycastResult.Normal
	local dotProduct = rayDirection:Dot(normal) 
	local reflection = rayDirection - 2 * dotProduct * normal
	return ClampVector3(reflection) :: Vector3
end
function Classic_Flagstand_Effect(Coordinate: (CFrame | Vector3)?, Size: number?, Parent: Instance?, Amount: number?, Fade_Duration: number?, Colour: Color3?, Material: Enum.Material?, Motion: Vector3?, ShrinkOrExpand: ('Shrink' | 'Expand')?, Size_Rate: number?, Filter: {Instance?}?)
	if typeof(Coordinate) == 'Vector3' then Coordinate = CFrame.new(Coordinate) end
	Amount = math.ceil(Amount)
	local Character = T.Parent
	local Subject = (Character or T)
	local Terrain = RaycastParams.new()
	Terrain.IgnoreWater = false
	Terrain.FilterType = Enum.RaycastFilterType.Include
	local RaycastParam = RaycastParams.new()
	RaycastParam.RespectCanCollide = true
	RaycastParam.IgnoreWater = true
	RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
	if not Coordinate then Coordinate = Subject:GetPivot()end if not Size then Size = 5 end if not Parent then Parent = workspace end if not Amount then	Amount = 3 end if not Fade_Duration then Fade_Duration = 10 end if not Colour then Colour = Color3.new(1, 1, 1) end if not Material then Material = Enum.Material.Neon end if not Motion then Motion = Vector3.new() end if not ShrinkOrExpand then ShrinkOrExpand = 'Expand' end if not Size_Rate then Size_Rate = 1/4 end if Colour and typeof(Colour) == 'BrickColor' then Colour = Colour.Color end if not Filter then Filter = {} end
	
	if Motion ~= Vector3.new() then
		RaycastParam.FilterDescendantsInstances = {}
		if Character then	RaycastParam:AddToFilter(Character) end -- Character
		RaycastParam:AddToFilter(Filter) -- Casted Instance
		RaycastParam:AddToFilter(EffectInstance) -- Previous Effect
		Terrain.FilterDescendantsInstances = {workspace:FindFirstChildOfClass('Terrain')}
		--[[for i,v in Filter do
			RaycastParam:AddToFilter(v)
		end]]
	end
	for i = 1,Amount do
		
		local effect = Instance.new("FlagStand", Parent)
		local lastamtick = tick()
		local coroute
		local GravityStack = 0
		local hit:RaycastResult?
		local lastpos: Vector3? = Coordinate.p or Subject:GetPivot().Position
		local corouteDis: RBXScriptConnection?
		local breakApart = (Motion ~= Vector3.new() and Colour ~= Color3.new(1, 1, 1) and Vector3.new(Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1),Random.new():NextInteger(-1,1))) or Vector3.new()
		effect.Size = (Size and Vector3.new(Size,Size,Size)) or Vector3.new(5,5,5)
		effect.Anchored = true
		effect.CanCollide = false
		effect.CanTouch = false
		effect.CanQuery = false
		effect.CastShadow = false
		effect.Color = Colour or Color3.new(1, 1, 1)
		effect.CFrame = Coordinate or CFrame.new()
		effect.Material = Material or Enum.Material.Neon
		RaycastParam:AddToFilter(effect)
		table.insert(EffectInstance, effect)
		Debris:AddItem(effect, (Fade_Duration*0.05) * 1.05)
		local Sized = effect.Size.X
		coroute = coroutine.create(function()
			
			lastamtick = tick()
			local Fade_Duration_Count = Fade_Duration
			task.delay(Fade_Duration - 1, function() if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end end)
			while task.wait() and Fade_Duration_Count > 0 do
				
				local delta = tick() - lastamtick
				local speed = 1 - .000001 ^ delta
				Fade_Duration_Count = Fade_Duration_Count - delta
				lastamtick = tick()
				
				if effect then
					local targetc = effect.CFrame targetc = (effect.CFrame + (Motion/1.25 + breakApart/1.25) * speed )* CFrame.fromEulerAnglesYXZ(Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3, Random.new():NextInteger(-1,1)/3)
					local targett = effect.Transparency + 1 * speed/Fade_Duration
					local Sizeb = effect.Size + effect.Size * Size_Rate * speed/Fade_Duration
					local Sizes = effect.Size - effect.Size * Size_Rate * speed/Fade_Duration
					
					--print('ea')
					effect.CFrame = targetc
					effect.Transparency = targett
					if ShrinkOrExpand == 'Expand' then
						effect.Size = Sizeb  --Vector3.new((Size/10)/Fade_Duration,(Size/10)/Fade_Duration,(Size/10)/Fade_Duration)
					elseif ShrinkOrExpand == 'Shrink' then
						effect.Size = Sizes
					end
				end
				
				if not hit and Motion ~= Vector3.new() and Colour ~= Color3.new(1, 1, 1) then
					
					hit = workspace:Raycast(effect.Position, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(effect.Position, -(Motion/1.25 + breakApart/1.25),RaycastParam) or workspace:Raycast(lastpos, Motion/1.25 + breakApart/1.25,RaycastParam) or workspace:Raycast(lastpos, effect.Position - lastpos,RaycastParam) or workspace:Raycast(effect.Position,lastpos - effect.Position,RaycastParam) or workspace:Raycast(lastpos, lastpos - effect.Position,RaycastParam) or workspace:Raycast(effect.Position,effect.Position - lastpos,RaycastParam)
					if hit then
						if hit.Material == Enum.Material.Water then
							if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end
							effect:Destroy()
						else
							
							local cloneeffect = effect:Clone()
							RaycastParam:AddToFilter(cloneeffect)
							if table.find(EffectInstance, effect) then table.remove(EffectInstance, table.find(EffectInstance, effect)) end
							table.insert(EffectInstance, cloneeffect)
							effect:Destroy()
							effect = nil
							cloneeffect.Parent = workspace
							--cloneeffect.Shape = Enum.PartType.Cylinder
							if hit.Instance:IsA("BasePart") then
								cloneeffect.Anchored = false
								local w = Instance.new('Weld', cloneeffect)
								w.Part1 = cloneeffect or hit.Instance
								w.Part0 = hit.Instance or cloneeffect
								local rx, ry, rz =  CFrame.new(lastpos, hit.Position) --[[Subject:GetPivot()]]:ToOrientation()
								local orientation = Vector3.new(math.deg(rx), math.deg(ry),math.deg(rz))
								local pcf = (CFrame.new(hit.Position , (hit.Position + hit.Normal--[[ + leg.CFrame.LookVector * Vector3.new(1,-1,1) ]])) * CFrame.Angles(0,0,ry):Inverse()) or (CFrame.new(effect.Position  , (effect.Position + hit.Normal --[[ + leg.CFrame.LookVector * Vector3.new(1,-1,1) ]])) * CFrame.Angles(0,0,ry):Inverse()) -- * savedlleg 
								local lpcf = pcf + Vector3.new(0,-0.05,0)
								w.C0 = hit.Instance.CFrame:ToObjectSpace(CFrame.new(hit.Position))  * pcf.Rotation --CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation + Vector3.new(0,0.01,0))
								if w.Part1 == w.Part0 then
									if cloneeffect then
										cloneeffect.Anchored = true
									end
									if w then
										w:Destroy()
									end
								else
									if cloneeffect then
										cloneeffect.Anchored = false
									end
								end
							else
								cloneeffect.Anchored = true 
								cloneeffect.CFrame = CFrame.new(hit.Position) * CFrame.Angles(math.rad(90),0,0)  * CFrame.new(hit.Position,hit.Position + hit.Normal).Rotation
							end
							cloneeffect.Size = Vector3.new(cloneeffect.Size.X * 2 + ((cloneeffect.Size.X + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,cloneeffect.Size.X * 2 + ((cloneeffect.Size.Y + cloneeffect.Size.Y) * cloneeffect.Size.Z) - 0.01,0.1)/1.5
							if ts then
								ts:Create(cloneeffect, TweenInfo.new(10 * (1 - cloneeffect.Transparency),Enum.EasingStyle.Sine,Enum.EasingDirection.Out),{Transparency = 1, Size = cloneeffect.Size * 0.75}):Play()
							end
							if Debris then Debris:AddItem(cloneeffect,10) task.delay(9, function() if table.find(EffectInstance, cloneeffect) then table.remove(EffectInstance, table.find(EffectInstance, cloneeffect)) end end) end
						end
						if hit.Instance and (not Character or Character and not hit.Instance:IsDescendantOf(Character)) then
							repeat 
								local Randomed = math.random()
								if Randomed < Sized then
									--print('uh' .. tostring(CFrame.new(hit.Position, hit.Position + hit.Normal).LookVector) )
									--print('uh' .. Randomed)
									--water splash
									coroutine.resume(coroutine.create(function()--[[ PlaySound('splat0wav', effect)]] Classic_Flagstand_Effect(CFrame.new(hit.Position),Randomed,workspace,math.random(1,2),Fade_Duration/2,Colour,Material,--[[-Motion/2]]--[[ CFrame.new(hit.Position, hit.Position + hit.Normal).LookVector * (Motion.Magnitude/7.5) +]] (HandleRaycastHit(Motion, hit).Magnitude/2) * calculateBounceAngle(Motion, hit).Unit --[[Randomed + breakApart/3]], ShrinkOrExpand, Size_Rate/2, Filter)  end))	
									Sized = Sized - Randomed
								else
									Sized = 0
									break
								end
							until not Sized or Sized <= 0 or not Randomed or not workspace or not game -- noway useless af
						end
					elseif not hit then
						
						Sized = effect.Size.X
						lastpos = effect.Position
						if Motion.Y < (-0.5 * 25) then
							Motion = Motion + Vector3.new(0,0.1,0) * speed -- slow rec as it inverse accelerates
							GravityStack = GravityStack - 1
						else -- until gravity balanced out
							Motion = Motion + Vector3.new(0,-0.25,0) * speed -- high gain as it accelerates
							GravityStack = GravityStack + 1
						end
					end
				end
				
				if effect and effect.Color == Color3.new(1,1,1) and effect.Material == Enum.Material.ForceField then
					local Back = workspace:Raycast(effect.Position, lastpos - effect.Position, Terrain) or workspace:Raycast(lastpos, effect.Position - lastpos, Terrain) or workspace:Raycast(lastpos, Vector3.new(0,1,0), Terrain) or workspace:Raycast(lastpos, Vector3.new(0,-1,0), Terrain)
					if Back and (Back.Material == Enum.Material.Air or Back.Material == Enum.Material.Water) then
						
						effect.Size = effect.Size * 2
						effect.Transparency = effect.Transparency + 0.5
						Debris:AddItem(effect,0.05)
					end -- Air Bubble
				end
				
				if (i >= Fade_Duration) or hit or not effect then
					coroute = nil
					if corouteDis then
						corouteDis:Disconnect()
						corouteDis = nil
					end
					if effect then
						if table.find(EffectInstance, effect) then
							table.remove(EffectInstance, table.find(EffectInstance, effect))
						end
						
						effect:Destroy()
					end
					break
				end
				
				if (i >= Fade_Duration) or not effect or hit ~= nil then
					return
				end
			end
		end)
		coroutine.resume(coroute)
		corouteDis = Subject.Destroying:Connect(function()
			
			if coroute then
				 coroutine.close(coroute)
			end
			
			if effect then
				 effect:Destroy()
			end
		end)
	end
end

function DrawLine(p1, p2, col, thick)
	local d = (p2 - p1).Magnitude
	if d < 0.01 then return end
	local p = Instance.new("Part")
	p.Anchored = true p.CanCollide = false p.CanQuery = false p.CanTouch = false
	p.Material = Enum.Material.Neon p.Color = col
	p.Size = Vector3.new(thick, thick, d)
	p.CFrame = CFrame.lookAt(p1, p2) * CFrame.new(0, 0, -d / 2)
	FadePart(p, DEBUG_LIFE)
	p.Parent = _DBG
end

function DrawPoint(pos, col, sz)
	local p = Instance.new("Part")
	p.Shape = Enum.PartType.Ball p.Anchored = true p.CanCollide = false
	p.CanQuery = false p.CanTouch = false p.Material = Enum.Material.Neon
	p.Color = col p.Size = Vector3.new(sz, sz, sz) p.Position = pos
	FadePart(p, DEBUG_LIFE)
	p.Parent = _DBG
end
-- Sound System
local VolumeMaster = 1.25

local SoundTabel = {
	['Metal clank'] = 'rbxassetid://117478490073055',
	['devyat clank'] = 'rbxassetid://136328625244043',
	['Ground Slam Impact Shockwave'] = 'rbxassetid://74149238738530',
}



function PlaySound(SoundName: string, ToWhere: Instance?, Volume: number?)
	if not Volume then Volume = VolumeMaster / 2 else Volume = math.clamp(Volume * VolumeMaster, 0, 10) end
	if not ToWhere then ToWhere = T end
	if FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound') then
		local snd = FindFirstChildOfNameAndClass(ToWhere, SoundName, 'Sound')
		snd.Volume = Volume * (0.9 + math.random() * 0.2)
		snd.PlaybackSpeed =   (0.9 + math.random() * 0.2)
		snd:Play()
	elseif SoundTabel[SoundName] then
		local snd = Instance.new('Sound')
		snd.Name = SoundName
		snd.SoundId = SoundTabel[SoundName]
		snd.Volume = Volume * (0.9 + math.random() * 0.2)
		snd.PlaybackSpeed =  (0.9 + math.random() * 0.2)
		snd.Parent = ToWhere
		snd:Play()
		game:GetService('Debris'):AddItem(snd, 10)
	end
end

function Clean()
	if typeof(TaskA) == 'thread' then
		task.cancel(TaskA)
	end if typeof(TaskB) == 'thread' then
		task.cancel(TaskB)
	end Act = false Deb = true Eq = false TaskA = nil TaskB = nil
	local cloned = T:FindFirstChild("Handle_C") if typeof(cloned) == 'Instance' then cloned:Destroy() end 
end

function GetStuck(CF: CFrame): Vector3 -- heavy, just heavy
	local Left = CF.Position - CF.RightVector
	local Right = CF.Position + CF.RightVector
	local Front = CF.Position + CF.LookVector
	local Back = CF.Position - CF.LookVector
	local Top = CF.Position + CF.UpVector
	local Bottom = CF.Position - CF.UpVector
	local LeftRay = workspace:Raycast(Left, Right - Left, PARAM)
	local RightRay = workspace:Raycast(Right, Left - Right, PARAM)
	local DownRay = workspace:Raycast(Top, Bottom - Top, PARAM)
	local UpRay = workspace:Raycast(Bottom, Top - Bottom, PARAM)
	local ForwardRay = workspace:Raycast(Back, Front - Back, PARAM)
	local BackwardRay = workspace:Raycast(Front, Back - Front, PARAM)
	local escape = Vector3.zero
	if typeof(LeftRay) == "RaycastResult" then escape += (Left - Right).Unit * (2 - LeftRay.Distance) end
	if typeof(RightRay) == "RaycastResult" then escape += (Right - Left).Unit * (2 - RightRay.Distance) end
	if typeof(DownRay) == "RaycastResult" then escape += (Top - Bottom).Unit * (2 - DownRay.Distance) end
	if typeof(UpRay) == "RaycastResult" then escape += (Bottom - Top).Unit * (2 - UpRay.Distance) end
	if typeof(ForwardRay) == "RaycastResult" then escape += (Back - Front).Unit * (2 - ForwardRay.Distance) end
	if typeof(BackwardRay) == "RaycastResult" then escape += (Front - Back).Unit * (2 - BackwardRay.Distance) end
	return escape
end

function updatergb()
	PCOL = (function() return Color3.fromRGB(math.abs(math.sin(tick())) * 255, math.abs(math.cos(tick())) * 125, 0) end)() 
	BCOL = (function() return Color3.fromRGB(math.abs(math.sin(tick())) * 125, math.abs(math.cos(tick())) * 255, 0) end)()
	DCOL = (function() return Color3.fromRGB(math.abs(math.sin(tick())) * 255, math.abs(math.cos(tick())) * 255, 0) end)()
end
T.Activated:Connect(function()
	if Act or not Eq or Deb or typeof(TaskA) == 'thread' or typeof(TaskB) == 'thread' then return end
	Act = true
	PlaySound('devyat clank', T)
	PARAM.FilterDescendantsInstances = {T.Parent, _DBG}
	TaskB = task.spawn(function()
		local __PATHED = {}
		local _hook = FindFirstChildOfNameAndClass(T, "Handle_C", "BasePart") 
		if typeof( _hook) ~= 'Instance' then
			_hook = FindFirstChildOfNameAndClass(T, "Handle", "BasePart")
		_hook = _hook:Clone()
		_hook.Parent = T
		_hook.Name = "Handle_C"
		_hook.Anchored = true end
		local __VEL = T:GetPivot().LookVector * math.random(80, 200) -- shoot toward tool's look direction with randomized magnitude
		local __PLR = nil
		local __POS = T:GetPivot().Position
		local __LAST = __POS
		DrawPoint(__POS, PCOL, 1.5)
		while __VEL.Magnitude > 0.001 and typeof(__PLR) ~= 'Instance' and #__PATHED < 100 do
			local Timer = task.wait() -- since I didn't use runServ and task.wait is not accurate(due to waiting for loop's task to be done), I used task.spawn()
			task.spawn(function() updatergb()
				--__POS = __POS + GetStuck(CFrame.new(-__VEL, __VEL).Rotation + __POS) -- makes it buggy yo
				local __MOVE = __VEL * Timer
				local __SCANNED = workspace:Raycast(__POS, __VEL, PARAM)
				local __SCANNED_MOVING = workspace:Raycast(__POS, __MOVE.Magnitude < 1 and __VEL.Unit * 1 or __MOVE, PARAM)
				if typeof(__SCANNED_MOVING) == 'RaycastResult' then
					if __SCANNED_MOVING.Instance:FindFirstAncestorWhichIsA('Model') and __SCANNED_MOVING.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass("Humanoid") and __SCANNED_MOVING.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass("Humanoid").Health > 0 then
						__PLR = __SCANNED_MOVING.Instance:FindFirstAncestorWhichIsA('Model')
						PlaySound('Ground Slam Impact Shockwave', T)
						return
					end
					local a = math.min(0,__SCANNED_MOVING.Normal:Dot(__VEL))
					__MOVE = __MOVE - __SCANNED_MOVING.Normal * math.min(0,__SCANNED_MOVING.Normal:Dot(__MOVE))
					__VEL = __VEL - __SCANNED_MOVING.Normal * a * 2 -- hard bounce
					table.insert(__PATHED, 1, {pos = __SCANNED_MOVING.Position, vel = __VEL})
					PlaySound('Metal clank', T, 0.3)
					DrawLine(__LAST, __SCANNED_MOVING.Position, PCOL, 0.4)
					DrawPoint(__SCANNED_MOVING.Position, BCOL, 1.2)
					Classic_Flagstand_Effect(CFrame.new(__SCANNED_MOVING.Position), 1, workspace, 5, 5, DCOL,Enum.Material.Neon,  __SCANNED_MOVING.Normal * math.abs(-a), "Shrink", 1, PARAM.FilterDescendantsInstances)
					__LAST = __SCANNED_MOVING.Position
				end
				if typeof(__SCANNED) == 'RaycastResult' then
					if __SCANNED.Instance:FindFirstAncestorWhichIsA('Model') and __SCANNED.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass("Humanoid") and __SCANNED.Instance:FindFirstAncestorWhichIsA('Model'):FindFirstChildOfClass("Humanoid").Health > 0 then
						__PLR = __SCANNED.Instance:FindFirstAncestorWhichIsA('Model')
						PlaySound('Ground Slam Impact Shockwave', T)
						return
					end
					--__VEL = __VEL - __SCANNED.Normal * math.min(0,__SCANNED.Normal:Dot(__VEL)) * 2 -- slow bender, it makes it perpendicular, no
				end
				__POS += __VEL * Timer
				DrawLine(__LAST, __POS, PCOL, 0.2)
				__LAST = __POS
				if _hook then
					_hook.CFrame =  CFrame.new(-__VEL, __VEL).Rotation * CFrame.Angles(math.pi/2, 0, 0) + __POS
					local pts = {T:GetPivot().Position}
					for i = #__PATHED, 1, -1 do
						table.insert(pts, __PATHED[i].pos)
					end
					table.insert(pts, __POS)
					--UpdateRopePath(pts)
				end
				__VEL *= 1 - math.min(1,Timer * 0.001)
				__VEL += Vector3.new(0, -9.8, 0) * Timer
			end)
		end
		if typeof(__PLR) ~= 'nil' then
			local humanoid = __PLR:FindFirstChildOfClass("Humanoid")
			local hrp = __PLR:FindFirstChild("HumanoidRootPart")
			if humanoid and hrp and #__PATHED > 0 then
				local ds = hrp.Position
				for i = #__PATHED, 1, -1 do
					DrawLine(ds, __PATHED[i].pos, DCOL, 0.3)
					DrawPoint(__PATHED[i].pos, DCOL, 0.8)
					ds = __PATHED[i].pos
				end
			end
			if humanoid and hrp and humanoid.Health > 0 then
				table.insert(__PATHED,{pos = T:GetPivot().Position, vel = Vector3.zero})
				humanoid.PlatformStand = true
				local oldFilter = PARAM.FilterDescendantsInstances
				PARAM.FilterDescendantsInstances = {T, __PLR, _DBG}
				local dVel = Vector3.zero
				local dPos = hrp.Position
				for i = 1, #__PATHED, 1 do
					local dragIn = i == #__PATHED
					if humanoid.Health <= 0 then break end
					local point = __PATHED[i]
					local target = dragIn and T:GetPivot().Position or point.pos
					while ((target - dPos).Magnitude > (dragIn and 3 or 1.41) or dVel.Magnitude > (dragIn and 32 or 16)) and humanoid.Health > 0 do
						if dragIn then 	target = T:GetPivot().Position end
						local dt = task.wait()
						task.spawn(function()
							updatergb()
						local toTarget = target - dPos
						local dist = toTarget.Magnitude
						local pathDir = toTarget.Unit
						local progress = (#__PATHED - i) / #__PATHED
						local accel = baseAccel * (1 + progress * 3)
						dVel += pathDir * accel * dt
						local perp = dVel - pathDir * dVel:Dot(pathDir)
						dVel -= perp * math.min(1, steerRate * dt)
						if dVel.Magnitude > maxSpeed then
							dVel = dVel.Unit * maxSpeed
						end
						_hook.Position = dPos
						local move = dVel * dt
						local hit = workspace:Raycast(dPos, move.Magnitude < 1 and move.Unit * 1 or move, PARAM)
						if typeof(hit) == 'RaycastResult' then
							dPos = hit.Position + hit.Normal * 0.5
							PlaySound('Metal clank', hit.Instance, 0.3)
							local impactSpeed = -math.min(0, hit.Normal:Dot(dVel))
							local dmg = math.clamp(impactSpeed * 0.05, 0, 100)
							if humanoid.Health > 0 then
								humanoid:TakeDamage(dmg)
							end
							local hitInst = hit.Instance
							local hitModel = hitInst:FindFirstAncestorWhichIsA('Model')
							if hitModel then
								local hitHum = hitModel:FindFirstChildOfClass('Humanoid')
								if hitHum and hitHum ~= humanoid and hitHum.Health > 0 then
									hitHum:TakeDamage(dmg)
								end
							end
							if hitInst:IsA('BasePart') and not hitInst.Anchored then
								hitInst.AssemblyLinearVelocity += dVel * 0.4 + hit.Normal * impactSpeed * 0.5
								end
								Classic_Flagstand_Effect(CFrame.new(hit.Position), 1, workspace, 5, 5, DCOL,Enum.Material.Neon,  hit.Normal * math.abs(math.min(0, hit.Normal:Dot(dVel))) , "Shrink", 1, PARAM.FilterDescendantsInstances)
							dVel = dVel - hit.Normal * math.min(0, hit.Normal:Dot(dVel)) * 1.5
							if impactSpeed > 20 then PlaySound('Ground Slam Impact Shockwave', hit.Instance, 0.4) end
							DrawPoint(dPos, DCOL, 1.0)
						else
							dPos = dPos + move
						end
						hrp.CFrame = CFrame.new(dPos)
						dPos = dPos + GetStuck(CFrame.new(-dVel, dVel).Rotation + dPos) -- clip this one
						DrawLine(hrp.Position, target, DCOL, 0.3)
						dVel = dVel * math.max(0,1 - dt)
						dVel += Vector3.new(0,-9.8 * dt,0) end)
					end
					dPos = target
					hrp.CFrame = CFrame.new(dPos)
					DrawPoint(point.pos, DCOL, 0.8)
					if i > 1 then
						local nextTarget = __PATHED[i - 1].pos
						local nextDir = (nextTarget - dPos).Unit
						dVel = nextDir * math.max(dVel.Magnitude, point.vel.Magnitude * 0.6)
					else
						dVel = dVel * 0.2
					end
				end
				PARAM.FilterDescendantsInstances = oldFilter
				humanoid.PlatformStand = false
				hrp.AssemblyLinearVelocity = dVel
			end
		end
		local cloned = T:FindFirstChild("Handle_C") if typeof(cloned) == 'Instance' then cloned:Destroy() end 
		Act = false
		TaskB = nil
	end)
end)
T.Deactivated:Connect(function()
	if not Act or not Eq then return end
	Act = false
	if TaskB then task.cancel(TaskB) end TaskB = nil
	local cloned = T:FindFirstChild("Handle_C") if typeof(cloned) == 'Instance' then cloned:Destroy() end 
end)
T.Unequipped:Connect(Clean) T.Destroying:Connect(Clean)
T.Equipped:Connect(function()
	Deb = true Eq = true
	TaskA = task.spawn(function() task.wait(1) if not Eq then return end
		Deb = false TaskA = nil
	end)
end)]]></ProtectedString>
